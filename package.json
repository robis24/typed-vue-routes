{
  "name": "typed-vue-routes",
  "version": "0.1.3",
  "type": "module",
  "description": "Code-first typed routing for Vue Router — defineRoute factory, runtime param casting, and a Vite plugin that generates typed-router.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robis24/typed-vue-routes.git"
  },
  "bugs": {
    "url": "https://github.com/robis24/typed-vue-routes/issues"
  },
  "homepage": "https://github.com/robis24/typed-vue-routes#readme",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "vite": ">=5.0.0",
    "vue": "^3.0.0",
    "vue-router": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6"
  }
}
